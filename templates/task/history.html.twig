{% extends 'base.html.twig' %}

{% block title %}Task History - TaskManager{% endblock %}

{% block body %}
    <div class="container mt-5">

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3 mt-3">

            <h3 class="mb-0 text-secondary fw-bold text-nowrap">Finished Tasks History</h3>

            <div class="d-flex flex-column flex-sm-row align-items-center gap-3">

                <div class="input-group input-group-sm shadow-sm" style="width: 250px;">
                    <input type="text" id="searchInput" class="form-control border-start-0 ps-1" placeholder="Search tasks..." aria-label="Search tasks">
                </div>

                <a href="{{ path('app_task') }}" class="btn btn-sm btn-outline-secondary shadow-sm text-nowrap">
                    &larr; Back to Open Tasks
                </a>

            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                    <tr>
                        <th>#ID</th>
                        <th>Task Title</th>
                        <th>Finished Date</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for task in taskList %}
                        <tr>
                            <td class="align-middle text-muted">{{ task.id }}</td>
                            <td class="align-middle fw-bold">
                                <div role="button" class="text-dark text-decoration-none custom-hover" data-bs-toggle="modal" data-bs-target="#viewModal-{{ task.id }}">
                                    {{ task.name }}
                                </div>
                            </td>
                            <td class="align-middle text-muted">
                                {{ task.finishedAt ? task.finishedAt|date('Y-m-d H:i') : '-' }}
                            </td>
                            <td class="align-middle">
                                <span class="badge bg-success shadow-sm">
                                    {{ task.status.name }}
                                </span>
                            </td>
                            <td class="text-end align-middle">
                                <form method="post" action="{{ path('app_task_restore', {task: task.id}) }}">
                                    <input type="hidden" name="_method" value="PATCH">
                                    <input type="hidden" name="_token" value="{{ csrf_token('restore' ~ task.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-success px-3 shadow-sm" title="Restore to Open">
                                        Restore
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                No finished tasks found in the history.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}

{# Estacionamento de Modais isolado do grid principal #}
{% block modals %}
    {% for task in taskList %}

        <div class="modal fade" id="viewModal-{{ task.id }}" tabindex="-1" aria-labelledby="viewModalLabel-{{ task.id }}" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content border-0 shadow-lg">

                    <div class="modal-header bg-light border-bottom-0 pt-4 px-4">
                        <h4 class="modal-title fw-bold text-dark" id="viewModalLabel-{{ task.id }}">
                            {{ task.name}}
                        </h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body px-4 pb-4 fs-6 text-secondary" style="white-space: pre-wrap;">
                        {% if task.description %}
                            {{ task.description }}
                        {% else %}
                            <em class="text-muted">No description provided for this task.</em>
                        {% endif %}

                        <hr class="my-4">
                        <p class="mb-0 text-muted small">
                            <strong>Finished on:</strong> {{ task.finishedAt ? task.finishedAt|date('Y-m-d H:i') : 'Unknown' }}
                        </p>
                    </div>

                    <div class="modal-footer bg-light border-0 px-4 py-3 d-flex justify-content-between align-items-center">
                        <span class="badge bg-secondary opacity-75">{{ task.category }}</span>

                        <div>
                            <button type="button" class="btn btn-outline-secondary px-4 shadow-sm" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    {% endfor %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('search') }}
{% endblock %}
