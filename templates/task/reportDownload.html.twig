<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Task Report</title>

    <style>
        {{ inline_css|raw }}

        {# Ajustes para PDF #}
        body {
            background-color: #ffffff;
            font-family: Arial, sans-serif;
            color: #333333;
            padding: 20px;
        }
        .report-header {
            border-bottom: 2px solid #2c3e50;
            padding-bottom: 15px;
            margin-bottom: 25px;
        }
        .filters-box {
            background-color: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 6px;
            padding: 15px;
            margin-bottom: 30px;
        }
        .table th {
            background-color: #2c3e50 !important;
            color: #ffffff !important;
        }
    </style>
</head>
<body>

{# CABEÇALHO #}
<div class="report-header d-flex justify-content-between align-items-end">
    <div>
        <h2 class="mb-1 fw-bold text-dark" style="color: #2c3e50;">TaskFlow Analytics</h2>
        <h5 class="text-muted mb-0">Tasks Export Report</h5>
    </div>
    <div class="text-end text-muted small">
        <strong>Generated on:</strong> {{ generatedAt|date('Y-m-d H:i') }}
    </div>
</div>


<div class="filters-box">
    <h6 class="fw-bold mb-3 text-uppercase" style="color: #2c3e50; font-size: 0.85rem; letter-spacing: 1px;">Applied Filters</h6>

    <div class="row text-sm">
        <div class="col-4">
            <span class="text-muted">Status:</span>
            <strong class="d-block mt-1">
                {% if filterStatus is not null %}

                    {% if filterStatus.value == 'open' %}
                        Only Open Tasks
                    {% elseif filterStatus.value == 'finished' %}
                        Only Finished Tasks
                    {% elseif filterStatus.value == 'deleted' %}
                        Only Deleted Tasks
                    {% endif%}

                {% else %}
                    All Tasks (Open, Finished & Deleted)
                {% endif %}
            </strong>
        </div>

        <div class="col-4">
            <span class="text-muted">Start Date:</span>
            <strong class="d-block mt-1">
                {{ filterDateStart ? filterDateStart|date('Y-m-d') : 'Beginning of Time' }}
            </strong>
        </div>

        <div class="col-4">
            <span class="text-muted">End Date:</span>
            <strong class="d-block mt-1">
                {{ filterDateEnd ? filterDateEnd|date('Y-m-d') : 'Today' }}
            </strong>
        </div>
    </div>
</div>

<table class="table table-striped table-bordered table-sm">
    <thead>
    <tr>
        <th style="width: 5%">#ID</th>
        <th style="width: 35%">Task Name</th>
        <th style="width: 15%">Category</th>
        <th style="width: 25%">Relevant Date</th>
        <th style="width: 20%" class="text-center">Status</th>
    </tr>
    </thead>
    <tbody>
    {% for task in taskList %}
        <tr>
            <td class="align-middle text-muted">{{ task.id }}</td>
            <td class="align-middle fw-bold">{{ task.name }}</td>
            <td class="align-middle">{{ task.category }}</td>
            <td class="align-middle text-muted small">
                {% if task.status.name == 'FINISHED' %}
                    Finished: {{ task.finishedAt ? task.finishedAt|date('Y-m-d H:i') : '-' }}
                {% elseif task.status.name == 'DELETED'%}
                    Deleted: {{ task.deletedAt ? task.deletedAt|date('Y-m-d H:i') : '-' }}
                {% else %}
                    Created: {{ task.createdAt ? task.createdAt|date('Y-m-d H:i') : '-' }}
                {% endif %}
            </td>
            <td class="align-middle text-center">
                {% if task.status.name == 'FINISHED' %}
                    <span style="color: #198754; font-weight: bold;">FINISHED</span>
                {% elseif task.status.name == 'DELETED'%}
                    <span style="color: #dc3545; font-weight: bold;">DELETED</span>
                {% else %}
                    <span style="color: #0d6efd; font-weight: bold;">OPEN</span>
                {% endif %}
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="5" class="text-center py-4 text-muted">
                No tasks found matching the selected filters.
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>

{# RODAPÉ #}
<div class="mt-4 pt-3 border-top text-center text-muted" style="font-size: 0.75rem;">
    <em>Report automatically generated by TaskManager System.</em>
    <br>
    <strong>Total records found:</strong> {{ taskList|length }}
</div>

</body>
</html>
