{% extends 'base.html.twig' %}

{% block title %}Trash - TaskManager{% endblock %}

{% block body %}
    <div class="container mt-5">

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3 mt-3">

            <div class="d-flex align-items-center gap-2">
                <h3 class="mb-0 text-secondary fw-bold text-nowrap">Trash</h3>
                <span class="badge bg-danger rounded-pill">{{ taskList|length }}</span>
            </div>

            <div class="d-flex flex-column flex-sm-row align-items-center gap-3">

                <div class="input-group input-group-sm shadow-sm" style="width: 250px;">
                    <input type="text" id="searchInput" class="form-control border-start-0 ps-1" placeholder="Search deleted tasks..." aria-label="Search tasks">
                </div>

                <a href="{{ path('app_task') }}" class="btn btn-sm btn-outline-secondary shadow-sm text-nowrap">
                    &larr; Back to Open Tasks
                </a>

            </div>
        </div>

        <div class="card shadow-sm border-0 border-danger border-opacity-25">
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                    <tr>
                        <th>#ID</th>
                        <th>Task Title</th>
                        <th>Deleted Date</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for task in taskList %}
                        <tr>
                            <td class="align-middle text-muted">{{ task.id }}</td>
                            <td class="align-middle fw-bold">
                                <div role="button" class="text-dark text-decoration-none custom-hover" data-bs-toggle="modal" data-bs-target="#viewModal-{{ task.id }}">
                                    <del class="text-muted">{{ task.name }}</del>
                                </div>
                            </td>
                            <td class="align-middle text-muted">
                                {{ task.deletedAt ? task.deletedAt|date('Y-m-d H:i') : '-' }}
                            </td>
                            <td class="align-middle">
                                <span class="badge bg-danger shadow-sm">
                                    {{ task.status.name }}
                                </span>
                            </td>
                            <td class="text-end align-middle">
                                <div class="d-flex justify-content-end gap-2">

                                    <form method="post" action="{{ path('app_task_restore', {task: task.id}) }}">
                                        <input type="hidden" name="_method" value="PATCH">
                                        <input type="hidden" name="_token" value="{{ csrf_token('restore' ~ task.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-success px-3 shadow-sm" title="Restore to Open">
                                            Restore
                                        </button>
                                    </form>

                                    <button type="button" class="btn btn-sm btn-danger px-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#deleteModal-{{ task.id }}">
                                        Delete Forever
                                    </button>

                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <div class="fs-1 mb-3">🗑️</div>
                                <h5>Your trash is empty.</h5>
                                <p class="small text-muted mb-0">No tasks have been deleted.</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}

{% block modals %}
    {% for task in taskList %}

        {# Modal de HARD Delete #}
        <div class="modal fade" id="deleteModal-{{ task.id }}" tabindex="-1" aria-labelledby="deleteModalLabel-{{ task.id }}" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg">

                    <div class="modal-header bg-danger text-white border-0">
                        <h5 class="modal-title fw-bold" id="deleteModalLabel-{{ task.id }}">Permanent Deletion</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body fs-6 py-4">
                        Are you absolutely sure you want to permanently delete <strong>"{{ task.name }}"</strong>? <br>
                        <div class="alert alert-warning mt-3 mb-0 small border-0 shadow-sm">
                            ⚠️ This will wipe the task from the database. This action cannot be undone or recovered.
                        </div>
                    </div>

                    <div class="modal-footer bg-light border-0">
                        <button type="button" class="btn btn-secondary px-3" data-bs-dismiss="modal">Cancel</button>

                        <form method="post" action="{{ path('app_task_hard_delete', {task: task.id}) }}">
                            <input type="hidden" name="_method" value="DELETE">
                            <input type="hidden" name="_token" value="{{ csrf_token('hard_delete' ~ task.id) }}">
                            <button type="submit" class="btn btn-danger px-4 shadow-sm">Yes, wipe it</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        {# Modal de View #}
        <div class="modal fade" id="viewModal-{{ task.id }}" tabindex="-1" aria-labelledby="viewModalLabel-{{ task.id }}" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content border-0 shadow-lg">

                    <div class="modal-header bg-light border-bottom-0 pt-4 px-4">
                        <h4 class="modal-title fw-bold text-dark text-decoration-line-through" id="viewModalLabel-{{ task.id }}">
                            {{ task.name}}
                        </h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body px-4 pb-4 fs-6 text-secondary" style="white-space: pre-wrap;">
                        {% if task.description %}
                            {{ task.description }}
                        {% else %}
                            <em class="text-muted">No description provided for this task.</em>
                        {% endif %}

                        <hr class="my-4">
                        <p class="mb-0 text-muted small">
                            <strong>Deleted on:</strong> {{ task.deletedAt ? task.deletedAt|date('Y-m-d H:i') : 'Unknown' }}
                        </p>
                    </div>

                    <div class="modal-footer bg-light border-0 px-4 py-3 d-flex justify-content-between align-items-center">
                        <span class="badge bg-secondary opacity-75">{{ task.category }}</span>
                        <button type="button" class="btn btn-outline-secondary px-4 shadow-sm" data-bs-dismiss="modal">Close</button>
                    </div>

                </div>
            </div>
        </div>

    {% endfor %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('search') }}
{% endblock %}
