{% extends 'base.html.twig' %}

{% block title %}My Tasks - TaskManager{% endblock %}

{% block body %}
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 mt-3">

        <h3 class="mb-3 mb-md-0 text-secondary fw-bold">Task list</h3>

        <div style="max-width: 250px; width: 100%;">
            <input type="text" id="searchInput" class="form-control form-control-sm shadow-sm" placeholder="Search tasks..." aria-label="Search tasks">
        </div>

    </div>

    <div class="row g-4 mt-3">

        {% for task in taskList %}
            <div class="col-12 col-md-6 col-lg-4 task-item">

                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">

                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div role="button" class="text-dark text-decoration-none custom-hover" data-bs-toggle="modal" data-bs-target="#viewModal-{{ task.id }}">
                                <h5 class="card-title mb-0 fw-bold">{{ task.name }}</h5>
                            </div>

                            {% set badge_color = 'bg-secondary' %}
                            {% if task.priority %}
                                {% if task.priority.id == 1 %}
                                    {% set badge_color = 'bg-success' %}
                                {% elseif task.priority.id == 2 %}
                                    {% set badge_color = 'bg-warning text-dark' %}
                                {% else %}
                                    {% set badge_color = 'bg-danger' %}
                                {% endif %}
                            {% endif %}
                            <span class="badge {{ badge_color }} shadow-sm">{{ task.priority }}</span>
                        </div>

                        <h6 class="card-subtitle mb-3 text-muted">
                            {{ task.category }}
                        </h6>

                        <div class="mt-auto pt-3 border-top">
                            <div class="d-flex justify-content-end gap-2">
                                <a href="{{ path('app_task_edit_form', {task: task.id}) }}" class="btn btn-sm btn-outline-primary px-3">
                                    Edit
                                </a>

                                <button type="button" class="btn btn-sm btn-outline-danger px-3" data-bs-toggle="modal" data-bs-target="#deleteModal-{{ task.id }}">
                                    Delete
                                </button>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center text-muted p-5 mt-4">
                No tasks found. Time to create one!
            </div>
        {% endfor %}

    </div>
{% endblock %}


{# Estacionamento de Modais isolado do grid principal #}

{% block modals %}
    {% for task in taskList %}
        {# Modal de delete #}
        <div class="modal fade" id="deleteModal-{{ task.id }}" tabindex="-1" aria-labelledby="deleteModalLabel-{{ task.id }}" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg">

                    <div class="modal-header bg-danger text-white border-0">
                        <h5 class="modal-title fw-bold" id="deleteModalLabel-{{ task.id }}">Confirm Deletion</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body fs-6 py-4">
                        Are you sure you want to delete the task <strong>"{{ task.name }}"</strong>? <br>
                        <span class="text-muted small">This action cannot be undone.</span>
                    </div>

                    <div class="modal-footer bg-light border-0">
                        <button type="button" class="btn btn-secondary px-3" data-bs-dismiss="modal">Cancel</button>

                        <form method="post" action="{{ path('app_task_delete', {task: task.id}) }}">
                            <input type="hidden" name="_method" value="DELETE">
                            <button type="submit" class="btn btn-danger px-4 shadow-sm">Yes, delete</button>
                        </form>
                    </div>

                </div>
            </div>
        </div>

        {# Modal de Descrição #}
        <div class="modal fade" id="viewModal-{{ task.id }}" tabindex="-1" aria-labelledby="viewModalLabel-{{ task.id }}" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content border-0 shadow-lg">

                    <div class="modal-header bg-light border-bottom-0 pt-4 px-4">
                        <h4 class="modal-title fw-bold text-dark" id="viewModalLabel-{{ task.id }}">
                            {{ task.name }}
                        </h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body px-4 pb-4 fs-6 text-secondary" style="white-space: pre-wrap;">
                        {% if task.description %}
                            {{ task.description }}
                        {% else %}
                            <em class="text-muted">No description provided for this task.</em>
                        {% endif %}
                    </div>

                    <div class="modal-footer bg-light border-0 px-4 py-3 d-flex justify-content-between">
                        <span class="badge bg-secondary opacity-75">{{ task.category }}</span>

                        <div>
                            <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Close</button>
                            <a href="{{ path('app_task_edit_form', {task: task.id}) }}" class="btn btn-primary px-4 shadow-sm">Edit Task</a>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    {% endfor %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('search') }}
{% endblock %}
