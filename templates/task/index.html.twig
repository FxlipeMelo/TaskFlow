{% extends 'base.html.twig' %}

{% block title %}Task List{% endblock %}

{% block body %}
<table class="table table-striped-columns">
    <caption>Lista de tarefas</caption>
    <thead>
        <tr>
            <th>id</th>
            <th scope="col">Task</th>
            <th scope="col">Category</th>
            <th scope="col">Priority</th>
        </tr>
    </thead>
    {% for task in taskList %}
        <tbody>
            {% set row_class = '' %}
            {% if task.priority%}
                {% if task.priority.id == 1 %}
                    {% set row_class = 'table-success' %}
                {% elseif(task.priority.id == 2) %}
                    {% set row_class = 'table-warning' %}
                {% else %}
                    {% set row_class = 'table-danger' %}
                {% endif %}
            {% endif %}

            <tr class="{{ row_class }}">
                <th scope="row">{{ task.id }}</th>
                <td>{{ task.name }}</td>
                <td>{{ task.category }}</td>
                <td>{{ task.priority }}</td>
                <td>
                    <div class="d-flex">
                        <a href="{{ path('app_task_edit_form', {task: task.id}) }}" class="btn btn-sm btn-primary me-2">E</a>
                            <form method="post" action="{{ path('app_task_delete', {task: task.id}) }}">
                            <input type="hidden" name="_method" value="DELETE">
                            <button type="submit" class="btn btn-sm btn-danger">X</button>
                        </form>
                    </div>
                </td>
            </tr>
        </tbody>
    {% endfor %}
</table>
{% endblock %}
