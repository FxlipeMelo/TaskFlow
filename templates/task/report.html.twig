                        </svg>
                        Download PDF
                    </button>
                </div>
            </form>

        </div>
    </div>

    {# FUTURO: PLACEHOLDERS DE GRÁFICOS #}
    {# DEIXAR AQUI POR ENQUANTO #}
    <div class="mt-5">
        <h5 class="fw-bold text-secondary mb-3">Overview</h5>
        <div class="row g-4">

            {# Card Vazio 1 #}
            <div class="col-12 col-md-4">
                <div class="card border-0 bg-white shadow-sm h-100 p-4 text-center rounded-4" style="border: 2px dashed #dee2e6 !important;">
                    <div class="text-muted mb-2 fs-1">📊</div>
                    <h6 class="text-secondary fw-bold">Completion Rate</h6>
                    <p class="text-muted small mb-0">Charts coming soon...</p>
                </div>
            </div>

            {# Card Vazio 2 #}
            <div class="col-12 col-md-4">
                <div class="card border-0 bg-white shadow-sm h-100 p-4 text-center rounded-4" style="border: 2px dashed #dee2e6 !important;">
                    <div class="text-muted mb-2 fs-1">📈</div>
                    <h6 class="text-secondary fw-bold">Tasks by Category</h6>
                    <p class="text-muted small mb-0">Charts coming soon...</p>
                </div>
            </div>

            {# Card Vazio 3 #}
            <div class="col-12 col-md-4">
                <div class="card border-0 bg-white shadow-sm h-100 p-4 text-center rounded-4" style="border: 2px dashed #dee2e6 !important;">
                    <div class="text-muted mb-2 fs-1">🔥</div>
                    <h6 class="text-secondary fw-bold">Productivity Streak</h6>
                    <p class="text-muted small mb-0">Charts coming soon...</p>
                </div>
            </div>

        </div>
    </div>
{% endblock %}
