{% extends 'base.html.twig' %}

{% block title %}Reports & Analytics{% endblock %}

{% block body %}
    {# Cabeçalho da Página #}
    <div class="mb-4">
        <h2 class="h3 text-secondary fw-bold mb-0">Reports & Analytics</h2>
        <p class="text-muted small">Export your data and track your productivity.</p>
    </div>

    {# CARD DE FILTROS E EXPORTAÇÃO #}
    <div class="card border-0 shadow-sm mb-5">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
            <h5 class="fw-bold text-secondary mb-0">Export Task Report</h5>
        </div>
        <div class="card-body p-4">

            <form action="{{ path('app_task_report_download') }}" class="row g-4" method="GET" target="_blank">

                <div class="col-12 col-md-4">
                    <label class="form-label text-muted small fw-bold text-uppercase">Status</label>
                    <select name="status" class="form-select form-select-lg bg-light border-0">
                        <option value="">All Tasks</option>
                        <option value="open">Open Only</option>
                        <option value="finished">Finished Only</option>
                        <option value="deleted">Deleted Only</option>
                    </select>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label text-muted small fw-bold text-uppercase">Start Date</label>
                    <input type="date" name="startDate" class="form-control form-control-lg bg-light border-0">
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label text-muted small fw-bold text-uppercase">End Date</label>
                    <input type="date" name="endDate" class="form-control form-control-lg bg-light border-0">
                </div>

                <div class="col-12 mt-4 pt-2 border-top">
                    <button type="submit" class="btn btn-danger btn-lg w-100 shadow-sm d-flex align-items-center justify-content-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-file-earmark-pdf-fill" viewBox="0 0 16 16">
                            <path d="M5.523 12.424c.14-.082.293-.162.459-.238a7.878 7.878 0 0 1-.45.606c-.28.337-.498.516-.635.572a.266.266 0 0 1-.035.012.282.282 0 0 1-.026-.044c-.056-.11-.054-.216.04-.36.106-.165.319-.354.647-.548zm2.455-1.647c-.119.025-.237.05-.356.078a21.148 21.148 0 0 0 .5-1.05 12.045 12.045 0 0 0 .51.858c-.217.032-.436.07-.654.114zm2.525.939a3.881 3.881 0 0 1-.435-.41c.228.005.434.022.612.054.317.057.466.147.518.209a.095.095 0 0 1 .026.064.436.436 0 0 1-.06.2.307.307 0 0 1-.094.124.107.107 0 0 1-.069.015c-.09-.003-.258-.066-.498-.256zM8.278 6.97c-.04.244-.108.524-.2.829a4.86 4.86 0 0 1-.089-.346c-.076-.353-.087-.73-.04-.96.051-.251.146-.316.25-.316.095 0 .165.07.179.193.015.132-.012.35-.1.604zm.09 3.493a11.332 11.332 0 0 1-.22-.381 9.387 9.387 0 0 1-.303-.591 10.61 10.61 0 0 1-.233-.506c-.057-.147-.11-.3-.159-.449a3.172 3.172 0 0 0-.17-.468c-.02-.046-.039-.089-.057-.13-.058-.135-.11-.271-.16-.407-.06-.16-.113-.322-.162-.482-.054-.18-.1-.362-.143-.544-.067-.282-.122-.56-.161-.82-.038-.254-.055-.494-.047-.714.009-.235.048-.445.109-.619.06-.17.14-.309.233-.404.093-.095.203-.153.33-.162.13-.01.27.027.418.093.15.068.303.17.447.299.146.13.282.288.406.467.124.178.235.378.332.593.097.214.178.441.242.673.064.232.11.472.139.712.03.24.04.482.029.718-.01.235-.043.465-.098.683-.056.216-.134.42-.234.606-.098.183-.222.348-.369.487-.146.138-.32.247-.523.315-.205.069-.441.106-.708.113zm-3.058 1.54c-.167.31-.284.604-.339.85-.053.243-.051.45.011.597.062.146.166.24.316.27.152.031.341.002.553-.082.21-.082.433-.217.658-.396.223-.178.444-.396.653-.642.21-.246.406-.514.582-.796.175-.281.332-.57.466-.856.135-.286.248-.567.339-.838.09-.271.16-.527.208-.763.048-.235.076-.445.086-.622.01-.176.002-.321-.025-.433-.027-.112-.073-.189-.136-.234-.063-.045-.144-.062-.24-.05a.736.736 0 0 0-.323.146c-.097.078-.18.175-.246.284-.065.108-.113.226-.145.347-.03.12-.043.24-.038.355.004.115.027.225.068.324.041.1.1.189.176.262.076.074.17.13.28.163zm7.04-1.879c-.274-.085-.59-.136-.94-.14