{% extends 'base.html.twig' %}

{% block title %}Check Your Email{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card shadow-sm border-0 mt-5">
                    <div class="card-body p-5 text-center">

                        <div class="mb-4 text-success">
                            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-envelope-check" viewBox="0 0 16 16">
                                <path d="M2 2a2 2 0 0 0-2 2v8.01A2 2 0 0 0 2 14h5.5a.5.5 0 0 0 0-1H2a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3.5a.5.5 0 0 0 1 0V4a2 2 0 0 0-2-2H2zm3.708 6.208L1 11.105V5.383l4.708 2.825zM1 4.217V4a.5.5 0 0 1 .5-.5h13a.5.5 0 0 1 .5.5v.217l-7 4.2-7-4.2z"/>
                                <path d="M16 12.5a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0zm-1.993-1.679a.5.5 0 0 0-.686.172l-1.17 1.95-.547-.547a.5.5 0 0 0-.708.708l.774.773a.75.75 0 0 0 1.174-.144l1.335-2.226a.5.5 0 0 0-.172-.686z"/>
                            </svg>
                        </div>

                        <h2 class="fw-bold mb-3">Check your inbox</h2>

                        <p class="text-muted mb-4">
                            If an account matching your email exists, we've sent an email with a link to reset your password.
                            <br><br>
                            <span class="badge bg-light text-dark border">
                            <i class="bi bi-clock"></i> Link expires in {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}
                        </span>
                        </p>

                        <div class="alert alert-light border text-start text-muted small mb-4" role="alert">
                            <strong>Didn't receive the email?</strong><br>
                            Please check your spam folder or
                            <a href="{{ path('app_forgot_password_request') }}" class="text-decoration-none fw-bold">try again</a>.
                        </div>

                        <div class="d-grid">
                            <a href="{{ path('app_login') }}" class="btn btn-outline-primary btn-lg">
                                Return to Login
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
