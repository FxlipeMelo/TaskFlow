<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body>

    <div class="d-flex wrapper" style="min-height: 100vh;">

        {% if is_granted('ROLE_USER') %}
        {# Menu lateral #}
        <div id="sidebar" class="d-none d-md-flex flex-column flex-shrink-0 p-3 text-bg-dark shadow" style="width: 260px;">
            <a href="{{ path('app_task') }}" class="d-flex align-items-center mb-4 mt-2 text-white text-decoration-none px-2">
                <span class="fs-4 fw-bold text-primary me-2">✓</span>
                <span class="fs-5 fw-semibold">Task Flow</span>
            </a>

            <ul class="nav nav-pills flex-column mb-auto gap-1">
                <li class="nav-item">
                    <a href="{{ path('app_task') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_task' ? 'active bg-primary text-white' : 'text-white opacity-75 custom-hover' }}">📋 My Tasks</a>
                </li>
                <li>
                    <a href="{{ path('app_task_create') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_task_create' ? 'active bg-primary text-white' : 'text-white opacity-75 custom-hover' }}">➕ New Task</a>
                </li>
                <li>
                    <a href="{{ path('app_task_history') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_task_history' ? 'active bg-primary text-white' : 'text-white opacity-75 custom-hover' }}">History</a>
                </li>
                <li>
                    <a href="{{ path('app_task_report') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_task_report' ? 'active bg-primary text-white' : 'text-white opacity-75 custom-hover' }}">Report</a>
                </li>
                <li>
                    <a href="{{ path('app_task_trash') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_task_trash' ? 'active bg-primary text-white' : 'text-white opacity-75 custom-hover' }}">Trash</a>
                </li>
            </ul>
            <ul class="nav nav-pills flex-column gap-1 mb-3">
                <li class="mt-3 mb-1">
                    <span class="text-white-50 small fw-bold px-3 text-uppercase" style="letter-spacing: 0.05em;">Settings</span>
                </li>
                <li>
                    <a href="{{ path('app_priority') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_priority' ? 'active bg-primary text-white' : 'text-white opacity-75 custom-hover' }}">Priority</a>
                </li>
                <li>
                    <a href="{{ path('app_category') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_category' ? 'active bg-primary text-white' : 'text-white opacity-75 custom-hover' }}">Category</a>
                </li>
            </ul>

            <hr>
            <div class="px-2 pb-2">
                    <a href="{{ path('app_logout') }}" class="btn btn-sm btn-outline-danger w-100">Logout</a>
            </div>
        </div>
        {% endif %}

        {# Area principal #}
        <div class="flex-grow-1 bg-light d-flex flex-column" style="min-width: 0;">

            {% if is_granted('ROLE_USER') %}
            <nav class="navbar navbar-light bg-white border-bottom shadow-sm px-3 py-2">
                <div class="d-flex align-items-center">

                    <button class="btn btn-sm btn-light border d-none d-md-block shadow-sm" id="desktopToggle">
                        <span class="fs-5">☰</span>
                    </button>

                    <button class="btn btn-sm btn-light border d-md-none shadow-sm" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu">
                        <span class="fs-5">☰</span>
                    </button>

                    <span class="ms-3 fw-bold text-secondary d-md-none">TaskManager</span>
                </div>
            </nav>
            {% endif %}

            <div class="container-fluid p-4 p-md-5">
                <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1055;">
                    {% for type, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="toast align-items-center text-bg-{{ type == 'success' ? 'success' : 'danger' }} border-0 shadow" role="alert" aria-live="assertive" aria-atomic="true" data-controller="toast">
                                <div class="d-flex">
                                    <div class="toast-body fw-bold">
                                        {{ message }}
                                    </div>
                                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                                </div>
                            </div>
                        {% endfor %}
                    {% endfor %}
                </div>

                {% block body %}{% endblock %}
            </div>
        </div>
    </div>

    {% if is_granted('ROLE_USER') %}
        <div class="offcanvas offcanvas-start text-bg-dark" tabindex="-1" id="mobileMenu">
            <div class="offcanvas-header border-bottom border-secondary">
                <h5 class="offcanvas-title fw-semibold"><span class="text-primary">✓</span> TaskManager</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body d-flex flex-column">
                <ul class="nav nav-pills flex-column mb-auto gap-2 mt-3">
                    <li class="nav-item">
                        <a href="{{ path('app_task') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_task_create' ? 'active bg-primary text-white' : 'text-white opacity-75 custom-hover' }}">📋 My Tasks</a>
                    </li>
                    <li>
                        <a href="{{ path('app_task_create') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_task_create' ? 'active bg-primary text-white' : 'text-white opacity-75 custom-hover' }}">➕ New Task</a>
                    </li>
                </ul>
                <ul class="nav nav-pills flex-column gap-2 mb-4 mt-4">
                    <li class="mt-2 mb-1 border-top border-secondary pt-2">
                        <span class="text-white-50 small fw-bold px-3 text-uppercase">Settings</span>
                    </li>
                    <li>
                        <a href="{{ path('app_priority') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_priority' ? 'active bg-primary text-white' : 'text-white opacity-75 custom-hover' }}">Priority</a>
                    </li>
                    <li>
                        <a href="{{ path('app_category') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_category' ? 'active bg-primary text-white' : 'text-white opacity-75 custom-hover' }}">Category</a>
                    </li>
                </ul>
            </div>
        </div>
    {% endif %}

    {%  block modals %}{% endblock %}
    </body>
</html>

