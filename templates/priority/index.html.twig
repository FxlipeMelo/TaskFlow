{% extends 'base.html.twig' %}

{% block title %}Priorities - TaskFlow{% endblock %}

{% block body %}
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 mt-3">
        <h3 class="mb-3 mb-md-0 text-secondary fw-bold">Priorities</h3>

        <a href="{{ path('app_priority_create_form') }}" class="btn btn-primary shadow-sm">
            ➕ New Priority
        </a>
    </div>

    {# CARD COM A LISTA VISUAL #}
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <ul class="list-group list-group-flush rounded-bottom">

                {% for priority in priorityList %}
                    <li class="list-group-item d-flex justify-content-between align-items-center p-3 border-light">

                        <span class="fw-semibold text-dark fs-5">
                            {{ priority.name }}
                        </span>

                        <div class="d-flex gap-2">
                            <a href="{{ path('app_priority_edit_form', {priority: priority.id}) }}"
                               class="btn btn-sm btn-outline-primary px-3">
                                Edit
                            </a>

                            <button type="button" class="btn btn-sm btn-outline-danger px-3" data-bs-toggle="modal"
                                    data-bs-target="#deleteModal-{{ priority.id }}">
                                Delete
                            </button>
                        </div>
                    </li>
                {% else %}
                    <li class="list-group-item text-center text-muted p-5">
                        No priorities found. Create your first one!
                    </li>
                {% endfor %}

            </ul>
        </div>
    </div>

    {% block modals %}

        {# ZONA DOS MODAIS (Isolada fora das listas para evitar bugs)  #}

        {% for priority in priorityList %}
            <div class="modal fade" id="deleteModal-{{ priority.id }}" tabindex="-1"
                 aria-labelledby="deleteModalLabel-{{ priority.id }}" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow-lg">

                        <div class="modal-header bg-danger text-white border-0">
                            <h5 class="modal-title fw-bold" id="deleteModalLabel-{{ priority.id }}">Confirm
                                Deletion</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                    aria-label="Close"></button>
                        </div>

                        <div class="modal-body fs-6 py-4">
                            Are you sure you want to delete the priority <strong>"{{ priority.name }}"</strong>? <br>
                            <span class="text-muted small">This action cannot be undone.</span>
                        </div>

                        <div class="modal-footer bg-light border-0">
                            <button type="button" class="btn btn-secondary px-3" data-bs-dismiss="modal">Cancel</button>

                            <form method="post" action="{{ path('app_priority_delete', {priority: priority.id}) }}">
                                <input type="hidden" name="_method" value="DELETE">
                                <button type="submit" class="btn btn-danger px-4 shadow-sm">Yes, delete</button>
                            </form>
                        </div>

                    </div>
                </div>
            </div>
        {% endfor %}
    {% endblock %}

{% endblock %}
