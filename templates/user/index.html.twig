{% extends 'base.html.twig' %}

{% block title %}Team Management - TaskFlow{% endblock %}

{% block body %}
    <div class="mb-4 mt-3 d-flex justify-content-between align-items-end">
        <div>
            <h3 class="mb-1 text-secondary fw-bold">Team Management</h3>
            <p class="text-muted small mb-0">Manage your corporate users, access levels, and security.</p>
        </div>

        {# Futuro botão para Admin convidar novos funcionários #}
        <button class="btn btn-primary shadow-sm px-4">
            + Invite Member
        </button>
    </div>

    <div class="card shadow-sm border-0 mb-5">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                <tr>
                    <th style="width: 5%">ID</th>
                    <th style="width: 30%">User</th>
                    <th style="width: 20%">Role</th>
                    <th style="width: 15%" class="text-center">Status</th>
                    <th style="width: 30%" class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for user in userList %}
                    <tr>
                        <td class="align-middle text-muted">{{ user.id }}</td>

                        <td class="align-middle">
                            <div class="fw-bold text-dark">
                                {% if user.firstName or user.lastName %}
                                    {{ user.firstName }} {{ user.lastName }}
                                {% else %}
                                    <span class="text-muted fst-italic">Pending Setup</span>
                                {% endif %}
                            </div>
                            <div class="small text-muted">{{ user.email }}</div>
                        </td>

                        <td class="align-middle text-muted">
                            {% if 'ROLE_ADMIN' in user.roles %}
                                <span class="badge bg-dark">Administrator</span>
                            {% else %}
                                <span class="badge bg-secondary">Member</span>
                            {% endif %}
                        </td>
                        <td class="align-middle text-center">
                            {% if user.status.value == 'active' %}
                                <span class="badge bg-success shadow-sm">ACTIVE</span>
                            {% else %}
                                <span class="badge bg-danger shadow-sm">INACTIVE</span>
                            {% endif %}
                        </td>
                        <td class="text-end align-middle">
                            {% if app.user and app.user.id == user.id %}
                                <div class="d-flex justify-content-end gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-secondary px-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#editProfileModal-{{ user.id }}">
                                        Profile
                                    </button>

                                    <button type="button" class="btn btn-sm btn-outline-danger px-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#securityModal-{{ user.id }}">
                                        Security
                                    </button>
                                </div>
                            {% else %}
                                <span class="text-muted small">Managed by Admin</span>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            No team members found.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}

{# ESTACIONAMENTO DE MODAIS #}
{% block modals %}
    {% for user in userList %}

        {# Se for o próprio usuário, renderizamos o modal dele #}
        {% if app.user and app.user.id == user.id %}

            <div class="modal fade" id="editProfileModal-{{ user.id }}" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow-lg">
                        <div class="modal-header bg-light border-0 pt-4 px-4">
                            <h5 class="modal-title fw-bold text-dark">Edit Personal Profile</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>

                        {{ form_start(formProfile, {
                            'action': path('app_user_profile_edit', {'user': user.id}),
                            'attr': {'data-turbo': 'false'}
                        }) }}
                            <div class="modal-body px-4 py-4 text-secondary">
                                <div class="row g-3">
                                    <div class="col-6">
                                        {{ form_row(formProfile.firstName, {
                                            'label_attr': {'class': 'form-label fw-bold small text-uppercase'},
                                            'attr': {'class': 'form-control bg-light border-0'}
                                        }) }}
                                    </div>
                                    <div class="col-6">
                                        {{ form_row(formProfile.lastName, {
                                            'label_attr': {'class': 'form-label fw-bold small text-uppercase'},
                                            'attr': {'class': 'form-control bg-light border-0'}
                                        }) }}
                                    </div>
                                    <div class="modal-footer bg-light border-0 px-4 py-3">
                                        <button type="button" class="btn btn-secondary px-3" data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-primary px-4 shadow-sm">Update Profile</button>
                                    </div>
                                </div>
                            </div>


                        {{ form_end(formProfile) }}
                    </div>
                </div>
            </div>

            <div class="modal fade" id="securityModal-{{ user.id }}" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow-lg">
                        <div class="modal-header bg-danger text-white border-0 pt-4 px-4">
                            <h5 class="modal-title fw-bold">Security & Access</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>

                        {{ form_start(formSecurity, {
                            'action': path('app_user_security_edit', {user: user.id}),
                            'attr': {'data-turbo': 'false'}
                        }) }}
                            <div class="modal-body px-4 py-4 text-secondary">
                                <div class="mb-4">
                                    {{ form_row(formSecurity.email, {
                                        'label_attr': {'class': 'form-label fw-bold small text-uppercase'},
                                        'attr': {'class': 'form-control bg-light border-0'}
                                    }) }}
                                </div>

                                <div class="mb-4">
                                    <button class="btn btn-sm btn-light border w-100 text-start d-flex justify-content-between align-items-center shadow-sm" type="button" data-bs-toggle="collapse" data-bs-target="#collapsePassword-{{ user.id }}" aria-expanded="false">
                                        <span class="fw-bold text-dark small text-uppercase">Change Password</span>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-down" viewBox="0 0 16 16">
                                            <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
                                        </svg>
                                    </button>

                                    <div class="collapse mt-2" id="collapsePassword-{{ user.id }}">
                                        <div class="card card-body bg-light border-0 p-3 shadow-inner">
                                            <div class="mb-2">
                                                {{ form_row(formSecurity.newPassword.first, {
                                                    'attr': {'class': 'form-control form-control-sm border-0 mb-2'}
                                                }) }}
                                                {{ form_row(formSecurity.newPassword.second, {
                                                    'attr': {'class': 'form-control form-control-sm border-0'}
                                                }) }}
                                            </div>
                                            <span class="small text-muted" style="font-size: 0.75rem;">Leave blank if you don't want to change it.</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="border-top pt-3">
                                    {{ form_row(formSecurity.currentPassword, {
                                        'label_attr': {'class': 'form-label fw-bold small text-uppercase text-danger'},
                                        'attr': {'class': 'form-control border-danger border-opacity-25'}
                                    }) }}
                                </div>

                            </div>
                            <div class="modal-footer bg-light border-0 px-4 py-3">
                                <button type="button" class="btn btn-secondary px-3" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-danger px-4 shadow-sm">Save Security Data</button>
                            </div>

                        {{ form_end(formSecurity) }}
                    </div>
                </div>
            </div>

        {% endif %}
    {% endfor %}

    <div id="modal-auto-open" data-target-id="{{ openModal|default('') }}"></div>
{% endblock %}
