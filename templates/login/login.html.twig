{% extends 'base.html.twig' %}

{% block title %}Login {% endblock %}

{% block body %}
    <div class="d-flex align-items-center justify-content-center" style="min-height: 80vh;">
        <div class="card shadow-lg border-0 p-4" style="width: 100%; max-width: 400px; border-radius: 1rem;">
            <div class="card-body">
                <div class="text-center mb-4">
                    <h3 class="fw-bold text-primary mb-1">Sign in</h3>
                    <p class="text-muted small">Log in to manage your tasks.</p>
                </div>

                {% if error %}
                    <div class="alert alert-danger text-center shadow-sm py-2" role="alert">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form action="{{ path('app_login') }}" method="post">
                    <div class="mb-3">
                        <label for="username" class="form-label text-secondary fw-semibold small">Email</label>
                        <input name="_username" type="text" class="form-control form-control-lg bg-light" id="username"
                               value="{{ last_username }}" placeholder="name@example.com">
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label text-secondary fw-semibold small">Password</label>
                        <input name="_password" type="password" class="form-control form-control-lg bg-light"
                               id="password" placeholder="...........">
                    </div>
                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection"
                           value="{{ csrf_token('authenticate') }}">
                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">Login</button>
                </form>

                <div class="text-center mt-4 pt-3 border-top">
                    <p class="text-muted small mb-0">
                        New to Task Flow?
                        <a href="{{ path('app_register') }}" class="text-primary text-decoration-none fw-semibold">Create an account</a>
                    </p>
                    <p class="text-muted small mb-0">
                        <a href="{{ path('app_forgot_password_request') }}" class="text-primary text-decoration-none fw-semibold">Forgot Password?</a>
                    </p>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
